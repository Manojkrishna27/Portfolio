# Copy to .env.local for local development.
# On Vercel, add these in Project Settings → Environment Variables.

# Public site URL (required for SEO / Open Graph on production)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# MongoDB (optional — static lib/* data is used when unset)
MONGODB_URI=

# Admin panel authentication
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# Contact form (SendGrid) — optional; form returns 503 when unset
SENDGRID_API_KEY=
SENDGRID_TO_EMAIL=
SENDGRID_FROM_NAME=Portfolio Contact

# Database seed endpoint protection
SEED_SECRET=
